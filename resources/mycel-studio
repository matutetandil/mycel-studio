#!/bin/bash
# Mycel Studio CLI launcher — opens a project directory in Mycel Studio.
# Usage: studio [directory]
#   studio .          — open current directory
#   studio /path/to   — open specific directory
#   studio            — open Mycel Studio without a project

DIR="${1:-.}"
ABS_DIR="$(cd "$DIR" 2>/dev/null && pwd)"

if [ -z "$ABS_DIR" ]; then
  echo "Error: directory '$DIR' does not exist" >&2
  exit 1
fi

# Find Mycel Studio.app — check common locations
APP=""
for candidate in \
  "/Applications/Mycel Studio.app" \
  "$HOME/Applications/Mycel Studio.app" \
  "$(dirname "$(dirname "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")")")/Mycel Studio.app"
do
  if [ -d "$candidate" ]; then
    APP="$candidate"
    break
  fi
done

if [ -z "$APP" ]; then
  echo "Error: Mycel Studio.app not found" >&2
  echo "Install it to /Applications or ~/Applications" >&2
  exit 1
fi

open -n "$APP" --args --project "$ABS_DIR"
